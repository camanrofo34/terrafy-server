    "/api/growing-systems/{userId}": {
      "get": {
        "summary": "RecuperarSistemasCrecimiento",
        "deprecated": false,
        "description": "",
        "tags": [],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "description": "",
            "required": true,
            "example": "2",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "",
            "required": false,
            "example": "1",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "",
            "required": false,
            "example": "10",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "query",
            "in": "query",
            "description": "",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sortOrder",
            "in": "query",
            "description": "",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "ASC",
                "DESC"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GrowingSystemList"
                },
                "example": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "title": "Listado de Sistemas de Cultivos",
                  "description": "Respuesta paginada que contiene una lista de sistemas de cultivos.",
                  "required": [
                    "systems",
                    "total",
                    "page",
                    "lastPage"
                  ],
                  "properties": {
                    "systems": {
                      "type": "array",
                      "description": "Lista de sistemas de cultivos.",
                      "items": {
                        "type": "object",
                        "required": [
                          "systemId",
                          "name",
                          "ubication",
                          "description",
                          "status",
                          "creationDate",
                          "updateDate"
                        ],
                        "properties": {
                          "systemId": {
                            "type": "integer",
                            "description": "Identificador único del sistema de cultivos.",
                            "example": 3
                          },
                          "name": {
                            "type": "string",
                            "description": "Nombre del sistema de cultivos.",
                            "minLength": 1
                          },
                          "ubication": {
                            "type": "string",
                            "description": "Ubicación física del sistema.",
                            "minLength": 1
                          },
                          "description": {
                            "type": "string",
                            "description": "Descripción detallada del sistema.",
                            "minLength": 1
                          },
                          "status": {
                            "type": "string",
                            "description": "Estado del sistema.",
                            "enum": [
                              "active",
                              "inactive"
                            ]
                          },
                          "creationDate": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Fecha de creación en formato ISO 8601."
                          },
                          "updateDate": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Fecha de última actualización en formato ISO 8601."
                          }
                        },
                        "additionalProperties": false
                      }
                    },
                    "total": {
                      "type": "integer",
                      "description": "Cantidad total de registros disponibles.",
                      "minimum": 0,
                      "example": 2
                    },
                    "page": {
                      "type": "integer",
                      "description": "Número actual de página.",
                      "minimum": 1,
                      "example": 1
                    },
                    "lastPage": {
                      "type": "integer",
                      "description": "Número total de páginas disponibles.",
                      "minimum": 1,
                      "example": 1
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "headers": {}
          },
          "403": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "headers": {}
          }
        },
        "security": [
          {
            "SesiónAgraria": []
          }
        ]
      }
    },
