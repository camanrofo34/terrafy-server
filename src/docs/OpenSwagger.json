  "webhooks": {},
  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Email del Usuario que desea iniciar sesión."
          },
          "password": {
            "type": "string",
            "description": "Contraseña del Usuario que desea iniciar sesión."
          }
        },
        "required": [
          "email",
          "password"
        ],
        "description": "Cuerpo de solicitud de Inicio de Sesión."
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Nombre completo del usuario que se está registrando."
          },
          "email": {
            "type": "string",
            "description": "Correo electrónico del usuario que se está registrando."
          },
          "password": {
            "type": "string",
            "description": "Contraseña del usuario que se está registrando. Mínimo 8 carácteres, una mayúscula, una minúscula y un símbolo.",
            "minLength": 8,
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&._])[A-Za-z\\d@$!%*?&._]{8,}$"
          }
        },
        "required": [
          "name",
          "email",
          "password"
        ]
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Nuevo nombre del usuario a editar"
          },
          "email": {
            "type": "string",
            "description": "Nuevo correo electrónico del usuario a editar"
          },
          "password": {
            "type": "string",
            "description": "Nueva contraseña del usuario a editar",
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&._])[A-Za-z\\d@$!%*?&._]{8,}$",
            "minLength": 8
          }
        }
      },
      "GrowingSystemCreationRequest": {
        "type": "object",
        "title": "",
        "description": "Representa un sistema de cultivos con información básica y el usuario asociado.",
        "required": [
          "systemId",
          "name",
          "ubication",
          "description",
          "status",
          "creationDate",
          "updateDate",
          "user"
        ],
        "properties": {
          "systemId": {
            "type": "integer",
            "description": "Identificador único del sistema de cultivos.",
            "examples": [
              2
            ]
          },
          "name": {
            "type": "string",
            "description": "Nombre del sistema de cultivos.",
            "minLength": 1,
            "examples": [
              "Cultivos1"
            ]
          },
          "ubication": {
            "type": "string",
            "description": "Ubicación física del sistema de cultivos.",
            "minLength": 1,
            "examples": [
              "Calle Verónica s/n."
            ]
          },
          "description": {
            "type": "string",
            "description": "Descripción detallada del sistema de cultivos.",
            "minLength": 1,
            "examples": [
              "Descripción del sistema..."
            ]
          },
          "status": {
            "type": "string",
            "description": "Estado actual del sistema de cultivos.",
            "enum": [
              "active",
              "inactive"
            ],
            "examples": [
              "active"
            ]
          },
          "creationDate": {
            "type": "string",
            "format": "date-time",
            "description": "Fecha de creación del sistema en formato ISO 8601.",
            "examples": [
              "2026-04-04T21:33:08.607Z"
            ]
          },
          "updateDate": {
            "type": "string",
            "format": "date-time",
            "description": "Fecha de última actualización del sistema en formato ISO 8601.",
            "examples": [
              "2026-04-04T21:33:08.607Z"
            ]
          },
          "user": {
            "type": "object",
            "description": "Información del usuario propietario del sistema.",
            "required": [
              "userId",
              "name",
              "email"
            ],
            "properties": {
              "userId": {
                "type": "integer",
                "description": "Identificador único del usuario.",
                "examples": [
                  2
                ]
              },
              "name": {
                "type": "string",
                "description": "Nombre completo del usuario.",
                "minLength": 1,
                "examples": [
                  "Camilo Rodriguez 2"
                ]
              },
              "email": {
                "type": "string",
                "format": "email",
                "description": "Correo electrónico del usuario.",
                "examples": [
                  "camanrofo@gmail.com"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "UpdateGrowingSystemRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Nuevo nombre del sistema de cultivo."
          },
          "location": {
            "type": "string",
            "description": "Nueva ubicación del sistema de cultivo."
          },
          "description": {
            "type": "string",
            "description": "Nueva descripción del sistema de cultivo."
          }
        }
      },
      "CreationGrowingSystemRequest": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "description": "Identificador del usuario que crea el sistema de cultivo NFT"
          },
          "name": {
            "type": "string",
            "description": "Nombre identificador del sistema de cultivo"
          },
          "location": {
            "type": "string",
            "description": "Ubicación del sistema de cultivo"
          },
          "description": {
            "type": "string",
            "description": "Descripción del sistema de cultivo."
          }
        },
        "required": [
          "userId",
          "name",
          "location"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "description": "Código HTTP representativo del error."
          },
          "timestamp": {
            "type": "string",
            "description": "Fecha y hora en la que se produjo el error."
          },
          "path": {
            "type": "string",
            "description": "Endpoint que produjo el error."
          },
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Definición exacta de la causa del error que se produjo."
              },
              "error": {
                "type": "string",
                "description": "Clase del error."
              },
              "statusCode": {
                "type": "number",
                "description": "Código HTTP representativo del error."
              }
            },
            "description": "Definición del error que se produjo.",
            "required": [
              "message",
              "error",
              "statusCode"
            ]
          }
        },
        "required": [
          "statusCode",
          "timestamp",
          "path",
          "error"
        ]
      },
      "SuccessfulLoginResponse": {
        "type": "object",
        "required": [
          "token",
          "user"
        ],
        "properties": {
          "token": {
            "type": "string",
            "minLength": 1,
            "description": "Token JWT de autenticación generado para el usuario"
          },
          "user": {
            "type": "object",
            "required": [
              "userId",
              "name",
              "email",
              "role",
              "status",
              "creationDate",
              "updateDate"
            ],
            "properties": {
              "userId": {
                "type": "integer",
                "minimum": 1,
                "description": "Identificador único del usuario"
              },
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 255,
                "description": "Nombre completo del usuario"
              },
              "email": {
                "type": "string",
                "format": "email",
                "maxLength": 255,
                "description": "Correo electrónico del usuario"
              },
              "role": {
                "type": "string",
                "enum": [
                  "agrarian",
                  "admin",
                  "customer"
                ],
                "description": "Rol asignado al usuario dentro del sistema"
              },
              "status": {
                "type": "string",
                "enum": [
                  "active",
                  "inactive",
                  "suspended"
                ],
                "description": "Estado actual del usuario"
              },
              "creationDate": {
                "type": "string",
                "format": "date-time",
                "description": "Fecha y hora de creación del usuario en formato ISO 8601"
              },
              "updateDate": {
                "type": "string",
                "format": "date-time",
                "description": "Fecha y hora de la última actualización en formato ISO 8601"
              }
            },
            "additionalProperties": false,
            "description": "Información detallada del usuario autenticado"
          }
        },
        "additionalProperties": false
      },
      "SuccessfulRegistrationUpdateResponse": {
        "type": "object",
        "required": [
          "userId",
          "name",
          "email",
          "role",
          "status",
          "creationDate",
          "updateDate"
        ],
        "properties": {
          "userId": {
            "type": "integer",
            "minimum": 1,
            "description": "Identificador único del usuario."
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "Nombre completo del usuario."
          },
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 255,
            "description": "Correo electrónico del usuario."
          },
          "role": {
            "type": "string",
            "enum": [
              "agrarian",
              "admin",
              "customer"
            ],
            "description": "Rol del usuario."
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "suspended"
            ],
            "description": "Estado actual del usuario."
